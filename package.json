{
  "name": "nasa-search",
  "version": "1.0.0",
  "description": "backend for nasa-search",
  "main": "app.js",
  "scripts": {
    "deploy": "npm run build && STAGE=prod cdk synth && STAGE=prod cdk deploy --require-approval never",
    "destroy": "STAGE=prod cdk destroy",
    "deploy:test": "npm run build && STAGE=test cdk synth && STAGE=test cdk deploy --require-approval never",
    "destroy:test": "STAGE=test cdk destroy",
    "build": "webpack",
    "build:watch": "webpack --watch",
    "build:local": "webpack --env local",
    "build:mocks": "webpack --env mocks",
    "watch:local": "webpack --watch --env local",
    "watch:mocks": "webpack --watch --env mocks",
    "serve:local": "ENV=local nodemon dist/app.js",
    "serve:mocks": "ENV=mocks nodemon dist/app.js",
    "dev:local": "npm run build:local && npm run serve:local & npm run watch:local",
    "dev:mocks": "npm run build:mocks && npm run serve:mocks & npm run watch:mocks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobg1/NasaSearch.git"
  },
  "keywords": [
    "Space"
  ],
  "author": "Jacob Greenwald",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jacobg1/NasaSearch/issues"
  },
  "homepage": "https://github.com/jacobg1/NasaSearch#readme",
  "dependencies": {
    "axios": "^1.14.0",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "lodash.uniqby": "^4.7.0",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.1118.0",
    "aws-cdk-lib": "^2.248.0",
    "constructs": "^10.6.0",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv": "^17.4.1",
    "msw": "^2.13.1",
    "nodemon": "^3.1.14",
    "terser-webpack-plugin": "^5.4.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-node-externals": "^3.0.0"
  }
}
